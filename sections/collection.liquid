{% comment %}
  Collection page — thin wrapper. All rendering logic lives in
  snippets/collection-grid.liquid so this section and the legacy
  sections/main-collection.liquid stay perfectly in sync.
{% endcomment %}

{%- render 'collection-grid',
  products_per_page: section.settings.products_per_page,
  enable_filtering:  section.settings.enable_filtering -%}

{% schema %}
{
  "name": "Collection",
  "tag": "section",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 24
    },
    {
      "type": "checkbox",
      "id": "enable_filtering",
      "label": "Enable filters sidebar",
      "info": "Requires Storefront Filters configured in Online Store → Search & Discovery.",
      "default": true
    }
  ],
  "presets": []
}
{% endschema %}
