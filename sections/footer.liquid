<footer class="site-footer" role="contentinfo">
  <div class="page-width">

    {%- comment -%} ── MAIN FOOTER GRID ── {%- endcomment -%}
    <div class="footer-grid">

      {%- comment -%} ── COL 1: BRAND ── {%- endcomment -%}
      <div class="footer-brand">
        <a href="{{ routes.root_url }}" class="footer-logo-link" aria-label="{{ shop.name }} — Home">
          {%- if settings.logo != blank -%}
            <img
              src="{{ settings.logo | image_url: width: 240 }}"
              alt="{{ shop.name }}"
              class="footer-logo"
              width="120"
              height="40"
              loading="lazy">
          {%- else -%}
            <img
              src="{{ 'logo-2.png' | asset_url }}"
              alt="{{ shop.name }}"
              class="footer-logo"
              width="120"
              height="40"
              loading="lazy">
          {%- endif -%}
        </a>
        <p class="footer-brand__desc">
          {{ section.settings.brand_description | default: 'Fine art materials for working professionals. Curated in Hermanus, trusted across South Africa.' }}
        </p>

        {%- comment -%} Social icons {%- endcomment -%}
        <div class="footer-social">
          {%- if section.settings.instagram != blank -%}
            <a
              href="{{ section.settings.instagram }}"
              target="_blank"
              rel="noopener noreferrer"
              class="footer-social__link"
              aria-label="Instagram">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                <path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/>
                <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
              </svg>
            </a>
          {%- endif -%}
          {%- if section.settings.facebook != blank -%}
            <a
              href="{{ section.settings.facebook }}"
              target="_blank"
              rel="noopener noreferrer"
              class="footer-social__link"
              aria-label="Facebook">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>
              </svg>
            </a>
          {%- endif -%}
        </div>
      </div>

      {%- comment -%} ── COL 2: SHOP ── {%- endcomment -%}
      <div class="footer-col">
        <h4 class="footer-heading">Shop</h4>
        <ul>
          {%- for link in linklists.footer-shop.links -%}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {%- else -%}
            <li><a href="{{ routes.collections_url }}/oil-painting">Oil Painting</a></li>
            <li><a href="{{ routes.collections_url }}/watercolour">Watercolour</a></li>
            <li><a href="{{ routes.collections_url }}/drawing">Drawing & Sketching</a></li>
            <li><a href="{{ routes.collections_url }}/canvas">Canvas & Paper</a></li>
            <li><a href="/collections/all">All Products</a></li>
          {%- endfor -%}
        </ul>
      </div>

      {%- comment -%} ── COL 3: HELP ── {%- endcomment -%}
      <div class="footer-col">
        <h4 class="footer-heading">Help</h4>
        <ul>
          {%- for link in linklists.footer-help.links -%}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {%- else -%}
            <li><a href="/pages/contact">Contact Us</a></li>
            <li><a href="/pages/shipping">Shipping Policy</a></li>
            <li><a href="/pages/returns">Returns</a></li>
            <li><a href="/pages/faq">FAQ</a></li>
          {%- endfor -%}
        </ul>
      </div>

      {%- comment -%} ── COL 4: VISIT & NEWSLETTER ── {%- endcomment -%}
      <div class="footer-col">
        <h4 class="footer-heading">Visit Us</h4>
        <div class="footer-visit">
          {%- if section.settings.address != blank -%}
            <p class="footer-visit__item">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
              {{ section.settings.address }}
            </p>
          {%- endif -%}
          {%- if section.settings.hours != blank -%}
            <p class="footer-visit__item">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
              {{ section.settings.hours }}
            </p>
          {%- endif -%}
          {%- if section.settings.email != blank -%}
            <p class="footer-visit__item">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
              <a href="mailto:{{ section.settings.email }}">{{ section.settings.email }}</a>
            </p>
          {%- endif -%}
        </div>

        {%- comment -%} Newsletter {%- endcomment -%}
        <div class="footer-newsletter">
          <p class="footer-newsletter__label">Stay in the loop</p>
          {%- form 'customer', id: 'FooterNewsletter' -%}
            <input type="hidden" name="contact[tags]" value="newsletter">
            {%- if form.posted_successfully? -%}
              <p class="footer-newsletter__success">You're subscribed.</p>
            {%- else -%}
              <div class="footer-newsletter__row">
                <input
                  type="email"
                  name="contact[email]"
                  class="footer-newsletter__input"
                  placeholder="your@email.com"
                  autocomplete="email"
                  required
                  aria-label="Email address for newsletter">
                <button type="submit" class="footer-newsletter__btn" aria-label="Subscribe">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <line x1="5" y1="12" x2="19" y2="12"/>
                    <polyline points="12 5 19 12 12 19"/>
                  </svg>
                </button>
              </div>
            {%- endif -%}
          {%- endform -%}
        </div>
      </div>

    </div>

    {%- comment -%} ── FOOTER BOTTOM BAR ── {%- endcomment -%}
    <div class="footer-bottom">
      <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
      <p class="footer-credit">
        Built by
        <a
          href="https://geararts.co.za"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GearArts Web">
          GearArts
        </a>
      </p>
    </div>

  </div>
</footer>


<style>
  /* ─── FOOTER ─── */
  /* Base .site-footer styles live in critical.css */

  /* ─── BRAND COL ─── */
  .footer-logo {
    width: auto;
    max-width: 140px;
    max-height: 48px;
    object-fit: contain;
    display: block;
    margin-bottom: var(--space-md);
    opacity: 0.85;
    filter: brightness(10); /* Makes dark logos visible on dark bg */
  }

  .footer-brand__desc {
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    color: var(--text-on-dark-muted);
    margin-bottom: var(--space-md);
    max-width: 260px;
  }

  /* ─── SOCIAL ─── */
  .footer-social {
    display: flex;
    gap: var(--space-sm);
  }

  .footer-social__link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border: var(--border-on-dark);
    border-radius: var(--radius-xs);
    color: var(--text-on-dark-muted);
    transition: var(--transition-fast);
  }

  .footer-social__link:hover {
    background: var(--color-maroon);
    border-color: var(--color-maroon);
    color: var(--color-white);
  }

  /* ─── NAV COLS ─── */
  .footer-heading {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-white);
    margin-bottom: var(--space-md);
  }

  .footer-col ul {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .footer-col a {
    font-size: var(--text-sm);
    color: var(--text-on-dark-muted);
    transition: var(--transition-fast);
    line-height: var(--leading-normal);
  }

  .footer-col a:hover {
    color: var(--color-white);
  }

  /* ─── VISIT ─── */
  .footer-visit {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    margin-bottom: var(--space-lg);
  }

  .footer-visit__item {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    font-size: var(--text-sm);
    color: var(--text-on-dark-muted);
    line-height: var(--leading-normal);
    margin: 0;
  }

  .footer-visit__item svg {
    flex-shrink: 0;
    margin-top: 3px;
    color: var(--color-maroon-light);
  }

  .footer-visit__item a {
    color: var(--text-on-dark-muted);
    transition: var(--transition-fast);
  }

  .footer-visit__item a:hover {
    color: var(--color-white);
  }

  /* ─── NEWSLETTER ─── */
  .footer-newsletter__label {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--text-on-dark-muted);
    margin-bottom: var(--space-xs);
  }

  .footer-newsletter__row {
    display: flex;
    border: var(--border-on-dark);
  }

  .footer-newsletter__input {
    flex: 1;
    background: transparent;
    border: none;
    padding: 10px var(--space-sm);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-white);
    outline: none;
    min-width: 0;
  }

  .footer-newsletter__input::placeholder {
    color: var(--text-on-dark-faint);
  }

  .footer-newsletter__btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background: var(--color-maroon);
    border: none;
    color: var(--color-white);
    cursor: pointer;
    flex-shrink: 0;
    transition: var(--transition-fast);
  }

  .footer-newsletter__btn:hover {
    background: var(--color-maroon-deep);
  }

  .footer-newsletter__success {
    font-size: var(--text-sm);
    color: var(--color-maroon-light);
    font-style: italic;
  }

  /* ─── BOTTOM BAR ─── */
  .footer-credit a {
    color: var(--color-maroon-light);
    transition: var(--transition-fast);
  }

  .footer-credit a:hover {
    color: var(--color-white);
  }
</style>


{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "textarea",
      "id": "brand_description",
      "label": "Brand description",
      "default": "Fine art materials for working professionals. Curated in Hermanus, trusted across South Africa."
    },
    {
      "type": "text",
      "id": "address",
      "label": "Store address",
      "default": "13 Mitchell St, Hermanus"
    },
    {
      "type": "text",
      "id": "hours",
      "label": "Store hours",
      "default": "Mon–Fri 9am–5pm · Sat 9am–2pm"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Contact email",
      "default": "artshophermanus@gmail.com"
    },
    {
      "type": "url",
      "id": "instagram",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "facebook",
      "label": "Facebook URL"
    }
  ],
  "presets": [
    {
      "name": "Footer"
    }
  ]
}
{% endschema %}
