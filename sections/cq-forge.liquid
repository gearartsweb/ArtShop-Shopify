{%- comment -%} CONQUEST — The Forge (featured products from a collection) {%- endcomment -%}
{%- assign coll = collections[section.settings.collection] -%}
<section class="cq cq-sec" id="cq-forge">
  <div class="cq-wrap">
    <div class="cq-sec-head cq-reveal">
      <div>
        {%- if section.settings.eyebrow != blank -%}<div class="idx">{{ section.settings.eyebrow }}</div>{%- endif -%}
        <h2>{{ section.settings.heading }}</h2>
      </div>
      {%- if section.settings.intro != blank -%}<p>{{ section.settings.intro }}</p>{%- endif -%}
    </div>

    <div class="cq-grid-prod">
      {%- if coll and coll.products.size > 0 -%}
        {%- for product in coll.products limit: section.settings.count -%}
          <a class="cq-card cq-reveal" href="{{ product.url }}">
            {%- if product.type != blank -%}<span class="tag">{{ product.type }}</span>{%- endif -%}
            <div class="thumb">
              {%- if product.featured_image -%}
                <img src="{{ product.featured_image | image_url: width: 700 }}"
                     alt="{{ product.featured_image.alt | escape | default: product.title }}"
                     width="700" height="700" loading="lazy">
              {%- else -%}
                <img class="mark" src="{{ 'conquest-mark.png' | asset_url }}" alt="{{ product.title }}" loading="lazy">
              {%- endif -%}
            </div>
            <h3>{{ product.title }}</h3>
            <div class="price">{{ product.price | money }}</div>
            <span class="buy">{{ section.settings.card_cta | default: 'Take it up' }} &rarr;</span>
          </a>
        {%- endfor -%}
      {%- else -%}
        {%- comment -%} Placeholder cards until a collection is chosen / products exist {%- endcomment -%}
        {%- for i in (1..section.settings.count) -%}
          <div class="cq-card cq-reveal">
            <span class="tag">Drop 01</span>
            <div class="thumb"><img class="mark" src="{{ 'conquest-mark.png' | asset_url }}" alt="" aria-hidden="true"></div>
            <h3>{{ 'onboarding.product_title' | t }}</h3>
            <div class="price">{{ 5000 | money }}</div>
            <span class="buy">Take it up &rarr;</span>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "CQ Forge",
  "settings": [
    { "type": "collection", "id": "collection", "label": "Collection to feature" },
    { "type": "range", "id": "count", "label": "Products shown", "min": 2, "max": 8, "step": 1, "default": 4 },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow / verse", "default": "What the Fire Made" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The Forge" },
    { "type": "textarea", "id": "intro", "label": "Intro", "default": "Every thread came through heat. Heavy cloth, dark ink, cut to be buried in and rise again." },
    { "type": "text", "id": "card_cta", "label": "Card call-to-action", "default": "Take it up" }
  ],
  "presets": [{ "name": "CQ Forge" }]
}
{% endschema %}
