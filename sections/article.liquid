{% comment %}
  Single article page — hero image, title, byline, body, and optional
  comments. Reuses the .rte typography from sections/page.liquid is NOT
  available here (scoped to that section), so this section ships its own.
  https://shopify.dev/docs/storefronts/themes/architecture/templates/article
{% endcomment %}

<article class="article-page">

  {% if article.image %}
    <div class="article-hero">
      <div class="article-hero__media">
        {{ article.image | image_url: width: 2000 | image_tag: loading: 'eager', fetchpriority: 'high', class: 'article-hero__img', alt: article.title | escape }}
      </div>
    </div>
  {% endif %}

  <div class="page-width page-width--narrow">

    <header class="article-header">
      {% if blog.title %}
        <a href="{{ blog.url }}" class="article-header__crumb">{{ blog.title }}</a>
      {% endif %}
      <h1 class="article-header__title">{{ article.title }}</h1>
      {% assign date = article.published_at | time_tag: format: 'date' %}
      <p class="article-header__meta">{{ 'blog.article_metadata_html' | t: date: date, author: article.author }}</p>
    </header>

    <div class="article-body rte">
      {{ article.content }}
    </div>

    {% if article.tags.size > 0 %}
      <div class="article-tags">
        {% for tag in article.tags %}
          <a href="{{ blog.url }}/tagged/{{ tag | handleize }}" class="article-tag">{{ tag }}</a>
        {% endfor %}
      </div>
    {% endif %}

    {% if blog.comments_enabled? %}
      <section class="article-comments" id="comments">
        <h2 class="article-comments__heading">{{ 'blog.article_comments' | t }}</h2>

        {% paginate article.comments by 10 %}
          {% if article.comments.size > 0 %}
            <ul class="comment-list">
              {% for comment in article.comments %}
                <li class="comment">
                  <p class="comment__author">{{ comment.author }}</p>
                  <p class="comment__date">{{ comment.created_at | time_tag: format: 'date' }}</p>
                  <div class="comment__body rte">{{ comment.content }}</div>
                </li>
              {% endfor %}
            </ul>

            {% if paginate.pages > 1 %}
              <div class="article-comments__pagination">
                {{ paginate | default_pagination: anchor: 'comments' }}
              </div>
            {% endif %}
          {% endif %}
        {% endpaginate %}

        {% form 'new_comment', article, class: 'comment-form' %}
          <h3 class="comment-form__heading">{{ 'blog.comment_form_title' | t }}</h3>

          {{ form.errors | default_errors }}

          <div class="comment-form__row">
            <label for="author" class="visually-hidden">{{ 'blog.comment_form_name' | t }}</label>
            <input
              type="text"
              name="comment[author]"
              id="author"
              value="{{ form.author }}"
              placeholder="{{ 'blog.comment_form_name' | t }}"
              required>
          </div>

          <div class="comment-form__row">
            <label for="email" class="visually-hidden">{{ 'blog.comment_form_email' | t }}</label>
            <input
              type="email"
              name="comment[email]"
              id="email"
              value="{{ form.email }}"
              placeholder="{{ 'blog.comment_form_email' | t }}"
              required>
          </div>

          <div class="comment-form__row">
            <label for="body" class="visually-hidden">{{ 'blog.comment_form_body' | t }}</label>
            <textarea
              name="comment[body]"
              id="body"
              rows="5"
              placeholder="{{ 'blog.comment_form_body' | t }}"
              required>{{ form.body }}</textarea>
          </div>

          <button type="submit" class="btn btn--primary">
            {{ 'blog.comment_form_submit' | t }}
          </button>
        {% endform %}
      </section>
    {% endif %}

  </div>
</article>

{% stylesheet %}
  .article-page {
    padding: 0 0 var(--space-2xl);
  }

  /* ── HERO ── */
  .article-hero {
    margin-bottom: var(--space-xl);
  }

  .article-hero__media {
    aspect-ratio: 16 / 9;
    max-height: 560px;
    overflow: hidden;
    background: var(--color-surface);
  }

  .article-hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ── HEADER ── */
  .article-header {
    text-align: center;
    padding-bottom: var(--space-lg);
    margin-bottom: var(--space-xl);
    border-bottom: var(--border-default);
  }

  .article-header__crumb {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-maroon);
    margin-bottom: var(--space-sm);
    transition: var(--transition-fast);
  }

  .article-header__crumb:hover {
    color: var(--color-maroon-deep);
  }

  .article-header__title {
    font-family: var(--font-serif);
    font-size: clamp(1.8rem, 4.5vw, 3rem);
    font-weight: 500;
    color: var(--text-primary);
    line-height: var(--leading-snug);
    margin-bottom: var(--space-md);
  }

  .article-header__meta {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--text-muted);
  }

  /* ── BODY (rich text) ── */
  .rte {
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--text-secondary);
  }

  .rte h2, .rte h3, .rte h4 {
    font-family: var(--font-serif);
    color: var(--text-primary);
    margin: var(--space-lg) 0 var(--space-sm);
    line-height: var(--leading-snug);
  }

  .rte h2 { font-size: var(--text-xl); }
  .rte h3 { font-size: var(--text-lg); }
  .rte h4 { font-size: var(--text-md); }

  .rte p { margin-bottom: var(--space-md); }

  .rte a {
    color: var(--color-maroon);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: var(--transition-fast);
  }

  .rte a:hover { color: var(--color-maroon-deep); }

  .rte ul, .rte ol {
    padding-left: var(--space-md);
    margin-bottom: var(--space-md);
  }

  .rte ul { list-style: disc; }
  .rte ol { list-style: decimal; }
  .rte li { margin-bottom: var(--space-xs); }

  .rte img {
    max-width: 100%;
    height: auto;
    margin: var(--space-md) 0;
    border-radius: var(--radius-xs);
  }

  .rte blockquote {
    border-left: 2px solid var(--color-maroon);
    padding-left: var(--space-md);
    margin: var(--space-md) 0;
    font-style: italic;
    color: var(--text-primary);
  }

  /* ── TAGS ── */
  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin: var(--space-xl) 0 var(--space-2xl);
    padding-top: var(--space-md);
    border-top: var(--border-light);
  }

  .article-tag {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    padding: 5px 12px;
    background: var(--color-maroon-ghost);
    border: var(--border-maroon);
    border-radius: var(--radius-xs);
    color: var(--color-maroon);
    transition: var(--transition-fast);
  }

  .article-tag:hover {
    background: var(--color-maroon);
    color: var(--color-white);
  }

  /* ── COMMENTS ── */
  .article-comments {
    margin-top: var(--space-2xl);
    padding-top: var(--space-xl);
    border-top: var(--border-default);
  }

  .article-comments__heading {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--text-primary);
    margin-bottom: var(--space-lg);
  }

  .comment-list {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-xl);
  }

  .comment {
    padding: var(--space-md) 0;
    border-bottom: var(--border-light);
  }

  .comment__author {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text-primary);
  }

  .comment__date {
    font-size: 11px;
    color: var(--text-muted);
    margin-bottom: var(--space-xs);
  }

  /* ── COMMENT FORM ── */
  .comment-form__heading {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--text-primary);
    margin-bottom: var(--space-md);
  }

  .comment-form__row {
    margin-bottom: var(--space-md);
  }

  .comment-form input,
  .comment-form textarea {
    width: 100%;
    padding: 12px var(--space-sm);
    background: var(--color-white);
    border: var(--border-default);
    border-radius: var(--radius-xs);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--text-primary);
    outline: none;
    transition: var(--transition-fast);
  }

  .comment-form input:focus,
  .comment-form textarea:focus {
    border-color: var(--color-maroon);
  }

  .comment-form input::placeholder,
  .comment-form textarea::placeholder {
    color: var(--text-muted);
  }

  .comment-form textarea {
    resize: vertical;
    min-height: 120px;
    line-height: var(--leading-normal);
  }

  @media screen and (max-width: 749px) {
    .article-hero { margin-bottom: var(--space-lg); }
    .article-header { margin-bottom: var(--space-lg); }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.article",
  "settings": []
}
{% endschema %}
