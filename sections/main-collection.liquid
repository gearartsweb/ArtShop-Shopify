{% comment %}
  DEPRECATED ALIAS — kept so legacy template references continue to
  render the polished UI. All rendering logic is in
  snippets/collection-grid.liquid, also used by sections/collection.liquid.

  No preset is exposed so this section cannot be selected from the
  theme editor. Use Collection instead.
{% endcomment %}

{%- render 'collection-grid',
  products_per_page: section.settings.products_per_page,
  enable_filtering:  section.settings.enable_filtering -%}

{% schema %}
{
  "name": "Main collection (legacy)",
  "tag": "section",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 24
    },
    {
      "type": "checkbox",
      "id": "enable_filtering",
      "label": "Enable filters sidebar",
      "default": true
    }
  ],
  "presets": []
}
{% endschema %}
