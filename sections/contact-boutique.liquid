<section class="contact-section">
  <div class="page-width">

    <div class="contact-grid">

      {%- comment -%} ── LEFT: INFO + SOCIAL ── {%- endcomment -%}
      <div class="contact-info">

        <span class="eyebrow">Get in Touch</span>
        <h2 class="contact-title">{{ section.settings.title | default: 'Inquiries & Commissions' }}</h2>
        <p class="contact-text">{{ section.settings.text | default: 'Whether you need a specific material, want to place a special order, or simply have a question — our team of working artists is here to help.' }}</p>

        <div class="contact-details">
          {%- if section.settings.address != blank -%}
            <div class="contact-detail">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
              <span>{{ section.settings.address }}</span>
            </div>
          {%- endif -%}

          {%- if section.settings.email != blank -%}
            <div class="contact-detail">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
              <a href="mailto:{{ section.settings.email }}">{{ section.settings.email }}</a>
            </div>
          {%- endif -%}

          {%- if section.settings.phone != blank -%}
            <div class="contact-detail">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.67A2 2 0 012.18 1h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 8.15a16 16 0 006.94 6.94l1.41-1.41a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
              </svg>
              <a href="tel:{{ section.settings.phone }}">{{ section.settings.phone }}</a>
            </div>
          {%- endif -%}

          {%- comment -%} Store hours if set {%- endcomment -%}
          {%- if section.settings.hours != blank -%}
            <div class="contact-detail">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
              <span>{{ section.settings.hours }}</span>
            </div>
          {%- endif -%}
        </div>

        {%- comment -%} ── SOCIAL CHANNELS ── {%- endcomment -%}
        <div class="contact-social">
          <span class="contact-social__label">Follow us</span>
          <div class="contact-social__buttons">

            {%- if section.settings.instagram != blank -%}
              <a
                href="{{ section.settings.instagram }}"
                target="_blank"
                rel="noopener noreferrer"
                class="social-btn social-btn--instagram"
                aria-label="Follow The Art Shop on Instagram">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                  <path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/>
                  <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
                </svg>
                Instagram
              </a>
            {%- endif -%}

            {%- if section.settings.facebook != blank -%}
              <a
                href="{{ section.settings.facebook }}"
                target="_blank"
                rel="noopener noreferrer"
                class="social-btn social-btn--facebook"
                aria-label="Follow The Art Shop on Facebook">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>
                </svg>
                Facebook
              </a>
            {%- endif -%}

          </div>
        </div>

      </div>

      {%- comment -%} ── RIGHT: FORM ── {%- endcomment -%}
      <div class="contact-form-wrapper">

        {%- form 'contact', id: 'ContactForm' -%}

          {%- if form.posted_successfully? -%}
            <div class="contact-success" role="alert">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              <p>Thank you. We'll be in touch shortly.</p>
            </div>
          {%- endif -%}

          {%- if form.errors -%}
            <div class="contact-error" role="alert">
              <p>{{ form.errors | default_errors }}</p>
            </div>
          {%- endif -%}

          <div class="contact-form">
            <div class="form-row">
              <div class="form-group">
                <label for="ContactName" class="form-label">Full Name</label>
                <input
                  type="text"
                  id="ContactName"
                  name="contact[name]"
                  class="form-input"
                  autocomplete="name"
                  required
                  value="{{ form.name }}">
              </div>
              <div class="form-group">
                <label for="ContactEmail" class="form-label">Email Address</label>
                <input
                  type="email"
                  id="ContactEmail"
                  name="contact[email]"
                  class="form-input"
                  autocomplete="email"
                  required
                  value="{{ form.email }}">
              </div>
            </div>

            <div class="form-group">
              <label for="ContactPhone" class="form-label">Phone (optional)</label>
              <input
                type="tel"
                id="ContactPhone"
                name="contact[phone]"
                class="form-input"
                autocomplete="tel"
                value="{{ form.phone }}">
            </div>

            <div class="form-group">
              <label for="ContactMessage" class="form-label">How can we help?</label>
              <textarea
                id="ContactMessage"
                name="contact[body]"
                class="form-input form-textarea"
                rows="5"
                required>{{ form.body }}</textarea>
            </div>

            <button type="submit" class="btn btn--primary btn--lg">
              Send Inquiry
            </button>
          </div>

        {%- endform -%}

      </div>

    </div>
  </div>
</section>


<style>
  /* ─── SECTION ─── */
  .contact-section {
    padding: var(--space-2xl) 0;
    background: var(--color-off-white);
    border-top: var(--border-default);
  }

  /* ─── GRID ─── */
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: var(--space-2xl);
    align-items: start;
  }

  /* ─── INFO SIDE ─── */
  .contact-title {
    font-family: var(--font-serif);
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 500;
    color: var(--text-primary);
    margin-bottom: var(--space-sm);
    line-height: var(--leading-snug);
  }

  .contact-text {
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--text-secondary);
    margin-bottom: var(--space-lg);
    max-width: 360px;
  }

  /* ─── CONTACT DETAILS ─── */
  .contact-details {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    margin-bottom: var(--space-xl);
  }

  .contact-detail {
    display: flex;
    align-items: flex-start;
    gap: var(--space-sm);
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }

  .contact-detail svg {
    flex-shrink: 0;
    margin-top: 2px;
    color: var(--color-maroon);
  }

  .contact-detail a {
    color: inherit;
    transition: var(--transition-fast);
  }

  .contact-detail a:hover {
    color: var(--color-maroon);
  }

  /* ─── SOCIAL ─── */
  .contact-social {
    border-top: var(--border-default);
    padding-top: var(--space-lg);
  }

  .contact-social__label {
    display: block;
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: var(--space-sm);
  }

  .contact-social__buttons {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .social-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px var(--space-md);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    border: var(--border-default);
    border-radius: var(--radius-xs);
    transition: var(--transition-fast);
    color: var(--text-primary);
    min-width: 150px;
    justify-content: center;
  }

  .social-btn--instagram:hover {
    background: linear-gradient(45deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888);
    color: var(--color-white);
    border-color: transparent;
  }

  .social-btn--facebook:hover {
    background: #1877F2;
    color: var(--color-white);
    border-color: transparent;
  }

  /* Mobile: show brand colours by default */
  @media screen and (max-width: 749px) {
    .social-btn--instagram {
      background: linear-gradient(45deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888);
      color: var(--color-white);
      border-color: transparent;
    }

    .social-btn--facebook {
      background: #1877F2;
      color: var(--color-white);
      border-color: transparent;
    }
  }

  /* ─── FORM SIDE ─── */
  .contact-form-wrapper {
    background: var(--color-white);
    border: var(--border-default);
    border-radius: var(--radius-md);
    padding: var(--space-xl);
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
    margin-bottom: var(--space-md);
  }

  .form-label {
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--text-secondary);
  }

  .form-input {
    width: 100%;
    padding: 12px 0;
    background: transparent;
    border: none;
    border-bottom: 1px solid rgba(26, 10, 10, 0.2);
    font-family: var(--font-sans);
    font-size: var(--text-base);
    color: var(--text-primary);
    outline: none;
    transition: var(--transition-fast);
    border-radius: 0;
  }

  .form-input:focus {
    border-bottom-color: var(--color-maroon);
  }

  .form-input::placeholder {
    color: var(--text-muted);
  }

  .form-textarea {
    resize: vertical;
    min-height: 120px;
  }

  /* ─── SUCCESS / ERROR ─── */
  .contact-success {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    background: rgba(26, 160, 90, 0.08);
    border: 1px solid rgba(26, 160, 90, 0.3);
    border-radius: var(--radius-sm);
    padding: var(--space-sm) var(--space-md);
    margin-bottom: var(--space-md);
  }

  .contact-success svg {
    color: #1aa05a;
    flex-shrink: 0;
  }

  .contact-success p {
    font-size: var(--text-sm);
    font-weight: 500;
    color: #1aa05a;
    margin: 0;
  }

  .contact-error {
    background: rgba(139, 26, 46, 0.06);
    border: 1px solid var(--color-maroon-border);
    border-radius: var(--radius-sm);
    padding: var(--space-sm) var(--space-md);
    margin-bottom: var(--space-md);
  }

  .contact-error p {
    font-size: var(--text-sm);
    color: var(--color-maroon);
    margin: 0;
  }

  /* ─── RESPONSIVE ─── */
  @media screen and (max-width: 990px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }

    .contact-text {
      max-width: 100%;
    }
  }

  @media screen and (max-width: 749px) {
    .contact-section {
      padding: var(--space-xl) 0;
    }

    .contact-form-wrapper {
      padding: var(--space-lg) var(--space-md);
    }

    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>


{% schema %}
{
  "name": "Boutique Contact",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Inquiries & Commissions"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Description",
      "default": "Whether you need a specific material, want to place a special order, or simply have a question — our team of working artists is here to help."
    },
    {
      "type": "text",
      "id": "address",
      "label": "Address",
      "default": "13 Mitchell St, Hermanus"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email",
      "default": "artshophermanus@gmail.com"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone number",
      "default": "+27 62 251 0546"
    },
    {
      "type": "text",
      "id": "hours",
      "label": "Store hours",
      "default": "Mon–Fri 9am–5pm · Sat 9am–2pm"
    },
    {
      "type": "url",
      "id": "instagram",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "facebook",
      "label": "Facebook URL"
    }
  ],
  "presets": [
    {
      "name": "Boutique Contact"
    }
  ]
}
{% endschema %}
