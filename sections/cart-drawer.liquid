{% comment %}
  Cart drawer — slides in from the right when the cart icon is tapped
  or after Add to Cart succeeds.

  CRITICAL: All JS here uses a plain <script> tag, NOT {% javascript %}.
  Shopify bundles {% javascript %} blocks asynchronously across sections,
  which means window.toggleCart may not exist when the header renders its
  onclick="window.toggleCart()". A plain <script> tag executes in document
  order and is always defined before the header button is clicked.
{% endcomment %}

<div
  id="cart-drawer-overlay"
  class="cart-drawer-overlay"
  onclick="window.toggleCart()"
  aria-hidden="true"></div>

<aside
  id="CartDrawer"
  class="cart-drawer"
  role="dialog"
  aria-label="Shopping cart"
  aria-hidden="true">

  <header class="cart-drawer-header">
    <h3>Your studio bag</h3>
    <button
      type="button"
      class="close-drawer"
      onclick="window.toggleCart()"
      aria-label="Close cart">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </header>

  <div id="CartDrawerItems" class="cart-drawer-scroll-area">
    {% render 'cart-drawer-items' %}
  </div>

  <footer id="CartDrawerFooter" class="cart-drawer-footer">
    {% if cart.item_count > 0 %}
      <div class="cart-total-row">
        <span>Total</span>
        <span>{{ cart.total_price | money }}</span>
      </div>
      <p class="shipping-note">Taxes and shipping calculated at checkout.</p>
      <a href="/checkout" class="drawer-checkout-btn">Proceed to checkout</a>
    {% endif %}
  </footer>
</aside>

<script>
  window.toggleCart = function() {
    var drawer  = document.getElementById('CartDrawer');
    var overlay = document.getElementById('cart-drawer-overlay');
    if (!drawer || !overlay) return;
    var open = !drawer.classList.contains('is-active');
    drawer.classList.toggle('is-active', open);
    overlay.classList.toggle('is-active', open);
    drawer.setAttribute('aria-hidden', String(!open));
    overlay.setAttribute('aria-hidden', String(!open));
    document.body.style.overflow = open ? 'hidden' : '';
    if (open) {
      var close = drawer.querySelector('.close-drawer');
      if (close) setTimeout(function() { close.focus(); }, 50);
    }
  };

  document.addEventListener('keydown', function(e) {
    if (e.key !== 'Escape') return;
    var drawer = document.getElementById('CartDrawer');
    if (drawer && drawer.classList.contains('is-active')) window.toggleCart();
  });

  /* Grabs the freshest cart-drawer markup by fetching /cart as HTML.
     We can't use the Section Rendering API (?sections=cart-drawer)
     because it only returns sections registered in the currently-served
     TEMPLATE, and cart-drawer is a LAYOUT section — so the response
     came back without our section, no swap happened, and the UI froze.
     Fetching /cart as HTML always includes the drawer (layout renders it
     on every page) and DOMParser lets us pluck the two containers we need. */
  window.refreshDrawer = function() {
    return fetch(window.Shopify.routes.root + 'cart?t=' + Date.now(), {
      headers: { 'X-Requested-With': 'XMLHttpRequest', 'Accept': 'text/html' }
    })
      .then(function(res) {
        if (!res.ok) throw new Error('Cart page fetch failed: ' + res.status);
        return res.text();
      })
      .then(function(html) {
        var doc     = new DOMParser().parseFromString(html, 'text/html');
        var itemsEl = document.getElementById('CartDrawerItems');
        var footEl  = document.getElementById('CartDrawerFooter');
        var ni      = doc.getElementById('CartDrawerItems');
        var nf      = doc.getElementById('CartDrawerFooter');
        if (ni && itemsEl) itemsEl.innerHTML = ni.innerHTML;
        if (nf && footEl)  footEl.innerHTML  = nf.innerHTML;
      });
  };

  window.updateQty = function(line, qty) {
    var itemsEl = document.getElementById('CartDrawerItems');
    if (itemsEl) itemsEl.style.opacity = '0.45';
    var params = new URLSearchParams();
    params.append('line',     parseInt(line, 10));
    params.append('quantity', parseInt(qty,  10));
    fetch(window.Shopify.routes.root + 'cart/change.js', {
      method:  'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'XMLHttpRequest' },
      body: params
    })
    .then(function(res) {
      if (!res.ok) return res.json().then(function(j) { throw new Error(j.description || 'Cart update failed'); });
      return res.json();
    })
    .then(function() {
      /* Always refresh from /cart — see refreshDrawer note above. */
      return window.refreshDrawer();
    })
    .then(function() {
      if (itemsEl) itemsEl.style.opacity = '1';
      if (window.TheArtShop && window.TheArtShop.updateCartCount) window.TheArtShop.updateCartCount();
      else if (window.updateCartCountBubble) window.updateCartCountBubble();
    })
    .catch(function(err) {
      console.error('Cart error:', err.message);
      if (itemsEl) itemsEl.style.opacity = '1';
      /* On sold-out / stock errors, refresh anyway so the UI matches truth. */
      if (/sold.?out|stock/i.test(err.message)) window.refreshDrawer();
    });
  };

  document.addEventListener('click', function(e) {
    var btn = e.target.closest('#CartDrawerItems [data-line]');
    if (!btn || btn.hasAttribute('disabled')) return;
    var line = parseInt(btn.getAttribute('data-line'), 10);
    var qty  = parseInt(btn.getAttribute('data-qty'),  10);
    if (!isNaN(line) && !isNaN(qty)) window.updateQty(line, qty);
  });
</script>

{% schema %}
{
  "name": "Cart drawer",
  "settings": []
}
{% endschema %}
