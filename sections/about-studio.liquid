<section class="about-studio" style="background-color: {{ section.settings.bg_color }};">
  <div class="page-width">
    <div class="about-grid">

      {%- comment -%} ── LEFT: IMAGE ── {%- endcomment -%}
      <div class="about-visual">
        <div class="about-image-wrapper">
          {%- if section.settings.image != blank -%}
            <img
              src="{{ section.settings.image | image_url: width: 1000 }}"
              alt="{{ shop.name }} — Fine Art Supply Store, Hermanus"
              loading="lazy"
              width="{{ section.settings.image.width }}"
              height="{{ section.settings.image.height }}"
              class="about-main-img">
          {%- else -%}
            {{ 'lifestyle-1' | placeholder_svg_tag: 'about-placeholder-svg' }}
          {%- endif -%}

          <div class="about-badge" aria-hidden="true">
            <span class="about-badge__year">Est.</span>
            <span class="about-badge__number">2006</span>
            <span class="about-badge__label">Hermanus</span>
          </div>
        </div>

        {%- comment -%} ── STAT ROW UNDER IMAGE ── {%- endcomment -%}
        <div class="about-stats">
          <div class="about-stat">
            <span class="about-stat__number">20+</span>
            <span class="about-stat__label">Years serving artists</span>
          </div>
          <div class="about-stat-divider" aria-hidden="true"></div>
          <div class="about-stat">
            <span class="about-stat__number">500+</span>
            <span class="about-stat__label">Professional grade SKUs</span>
          </div>
          <div class="about-stat-divider" aria-hidden="true"></div>
          <div class="about-stat">
            <span class="about-stat__number">W. Cape</span>
            <span class="about-stat__label">Creative community hub</span>
          </div>
        </div>
      </div>

      {%- comment -%} ── RIGHT: CONTENT ── {%- endcomment -%}
      <div class="about-content">
        <span class="eyebrow">
          {%- if section.settings.eyebrow != blank -%}
            {{ section.settings.eyebrow }}
          {%- else -%}
            Our Story
          {%- endif -%}
        </span>

        <h2 class="about-heading">
          {{ section.settings.title | default: 'The Art Shop Hermanus' }}
        </h2>

        <div class="about-description">
          {%- if section.settings.text != blank -%}
            {{ section.settings.text }}
          {%- else -%}
            <p>For over Two Decades, The Art Shop Hermanus has been the Western Cape's most trusted destination for professional fine art materials. What began as a local retail space has grown into a cornerstone of the region's creative community.</p>
            <p>We specialise in high-end fine art supplies — a curated selection of local and imported materials chosen by artists, for artists. Our philosophy is simple: premium quality shouldn't come with a premium barrier.</p>
            <p>When you walk through our doors, you aren't just a customer — you're a peer. Our promise is a professional, helpful experience defined by genuine knowledge and a commitment to your craft.</p>
          {%- endif -%}
        </div>

        <div class="about-features">
          <div class="about-feature">
            <span class="about-feature__title">Premium & Accessible</span>
            <p class="about-feature__text">Stretched margins so top-tier materials stay within reach of every serious artist.</p>
          </div>
          <div class="about-feature">
            <span class="about-feature__title">Artist to Artist</span>
            <p class="about-feature__text">Our team are practitioners. We stock what we use, and we know why it matters.</p>
          </div>
          <div class="about-feature">
            <span class="about-feature__title">Curated, Not Catalogued</span>
            <p class="about-feature__text">Every product earns its place. We source with intention, not to fill shelves.</p>
          </div>
          <div class="about-feature">
            <span class="about-feature__title">Special Orders Welcome</span>
            <p class="about-feature__text">Don't see what you need? We'll source it. No request is too specific.</p>
          </div>
        </div>

        <a href="/pages/about" class="btn btn--secondary">
          Our full story
        </a>
      </div>

    </div>
  </div>
</section>

<style>
  .about-studio {
    padding: var(--space-2xl) 0;
    border-top: var(--border-default);
  }

  /* ─── TWO-COLUMN GRID ─── */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-2xl);
    align-items: start;
  }

  /* ─── LEFT: VISUAL ─── */
  .about-visual {
    position: sticky;
    top: 84px; /* clears the sticky header */
  }

  .about-image-wrapper {
    position: relative;
    margin-bottom: var(--space-md);
  }

  .about-main-img,
  .about-placeholder-svg {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--radius-sm);
    filter: grayscale(15%);
  }

  /* Badge — positioned relative to wrapper, not flying off */
  .about-badge {
    position: absolute;
    bottom: calc(-1 * var(--space-md));
    right: calc(-1 * var(--space-md));
    background: var(--color-maroon);
    color: var(--color-white);
    padding: var(--space-md);
    text-align: center;
    min-width: 90px;
    transform: rotate(-4deg);
    border-radius: var(--radius-xs);
  }

  .about-badge__year {
    display: block;
    font-size: 9px;
    font-weight: 500;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    opacity: 0.7;
  }

  .about-badge__number {
    display: block;
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    font-weight: 500;
    line-height: 1.1;
  }

  .about-badge__label {
    display: block;
    font-size: 9px;
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    opacity: 0.7;
    margin-top: 3px;
  }

  /* ─── STATS ROW ─── */
  .about-stats {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-top: var(--space-xl);
    padding: var(--space-md) 0;
    border-top: var(--border-default);
    border-bottom: var(--border-default);
  }

  .about-stat {
    flex: 1;
    text-align: center;
  }

  .about-stat__number {
    display: block;
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    font-weight: 500;
    color: var(--color-maroon);
    line-height: 1;
    margin-bottom: 4px;
  }

  .about-stat__label {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--text-muted);
    line-height: 1.4;
  }

  .about-stat-divider {
    width: 1px;
    height: 36px;
    background: var(--color-surface);
    flex-shrink: 0;
  }

  /* ─── RIGHT: CONTENT ─── */
  .about-heading {
    font-family: var(--font-serif);
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 500;
    line-height: var(--leading-snug);
    color: var(--text-primary);
    margin-bottom: var(--space-md);
  }

  .about-description {
    margin-bottom: var(--space-lg);
  }

  .about-description p {
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--text-secondary);
    margin-bottom: var(--space-sm);
  }

  .about-description p:last-child {
    margin-bottom: 0;
  }

  /* ─── FEATURE GRID ─── */
  .about-features {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md) var(--space-lg);
    padding: var(--space-lg) 0;
    border-top: var(--border-default);
    border-bottom: var(--border-default);
    margin-bottom: var(--space-lg);
  }

  .about-feature__title {
    display: block;
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--text-primary);
    margin-bottom: var(--space-2xs);
  }

  .about-feature__text {
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    color: var(--text-muted);
    margin: 0;
  }

  /* ─── RESPONSIVE ─── */
  @media screen and (max-width: 990px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }

    .about-visual {
      position: relative;
      top: 0;
    }

    .about-badge {
      bottom: calc(-1 * var(--space-sm));
      right: var(--space-sm);
    }
  }

  @media screen and (max-width: 749px) {
    .about-studio {
      padding: var(--space-xl) 0;
    }

    .about-features {
      grid-template-columns: 1fr;
      gap: var(--space-md);
    }

    .about-stats {
      gap: var(--space-sm);
    }

    .about-stat__number {
      font-size: var(--text-lg);
    }
  }
</style>

{% schema %}
{
  "name": "About Studio",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Our Story"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "The Art Shop Hermanus"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Description",
      "info": "Leave blank to use the default store description"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Store image"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background colour",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "About Studio"
    }
  ]
}
{% endschema %}
