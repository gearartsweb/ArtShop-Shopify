{% comment %}
  Renders the body of the cart drawer — empty state OR list of line items
  with quantity stepper and remove button.

  Each control carries data-line + data-qty; the delegated click handler
  on #CartDrawerItems (in cart-drawer.liquid) calls window.updateQty.
  This survives the innerHTML swap when the drawer is re-fetched.

  Usage:
    {% render 'cart-drawer-items' %}
{% endcomment %}

{% if cart.item_count == 0 %}
  <div class="cart-empty">
    <svg class="cart-empty__icon" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true">
      <circle cx="9" cy="21" r="1"/>
      <circle cx="20" cy="21" r="1"/>
      <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
    </svg>
    <p class="cart-empty__text">Your studio bag is currently empty.</p>
  </div>
{% else %}
  <ul class="cart-drawer-items-list">
    {% for item in cart.items %}
      {% comment %} We use forloop.index (line number) for stable cart updates. {% endcomment %}
      <li class="cart-drawer-item">
        <a href="{{ item.url }}" class="cart-item-image-wrapper" tabindex="-1" aria-hidden="true">
          <img
            src="{{ item.image | image_url: width: 150 }}"
            loading="eager"
            alt=""
            width="72"
            height="72"
            class="cart-item-img">
        </a>

        <div class="cart-item-details">
          <a href="{{ item.url }}" class="cart-item-title">{{ item.product.title }}</a>

          {% unless item.variant.title contains 'Default' %}
            <p class="cart-item-variant">{{ item.variant.title }}</p>
          {% endunless %}

          <p class="cart-item-price">{{ item.final_line_price | money }}</p>

          {% if item.variant.inventory_management == 'shopify' and item.variant.inventory_quantity <= 0 and item.variant.inventory_policy == 'deny' %}
            <span class="cart-item-soldout">Sold out</span>
          {% endif %}

          <div class="cart-item-controls">
            <div class="qty-stepper" role="group" aria-label="Quantity for {{ item.product.title | escape }}">
              <button
                type="button"
                class="qty-stepper__btn"
                aria-label="Decrease quantity"
                data-line="{{ forloop.index }}"
                data-qty="{{ item.quantity | minus: 1 }}"
                {% if item.quantity <= 1 %}disabled{% endif %}>−</button>
              <span class="qty-stepper__value" aria-live="polite">{{ item.quantity }}</span>
              <button
                type="button"
                class="qty-stepper__btn"
                aria-label="Increase quantity"
                data-line="{{ forloop.index }}"
                data-qty="{{ item.quantity | plus: 1 }}">+</button>
            </div>

            <button
              type="button"
              class="remove-link"
              data-line="{{ forloop.index }}"
              data-qty="0"
              aria-label="Remove {{ item.product.title | escape }} from cart">Remove</button>
          </div>
        </div>
      </li>
    {% endfor %}
  </ul>
{% endif %}
