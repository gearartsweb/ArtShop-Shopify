{%- comment -%}
  SNIPPET: product-card.liquid
  Usage: {% render 'product-card', product: product %}
  Renders a single product card for grids and carousels.
{%- endcomment -%}

{%- assign first_variant = product.selected_or_first_available_variant -%}
{%- assign card_available = product.available -%}

<div class="studio-product-card{% unless card_available %} studio-product-card--sold-out{% endunless %}"
     data-product-id="{{ product.id }}">

  {%- comment -%} ── IMAGE FRAME ── {%- endcomment -%}
  <div class="image-frame">
    <a href="{{ product.url }}" class="product-card__image-link" aria-label="{{ product.title | escape }}">

      {%- comment -%} Grade badge from product tags {%- endcomment -%}
      {%- if product.tags contains 'Artist Grade' -%}
        <span class="product-grade-badge" aria-hidden="true">Artist Grade</span>
      {%- elsif product.tags contains 'Studio Grade' -%}
        <span class="product-grade-badge product-grade-badge--maroon" aria-hidden="true">Studio Grade</span>
      {%- elsif product.tags contains 'New In' -%}
        <span class="product-grade-badge product-grade-badge--maroon" aria-hidden="true">New In</span>
      {%- endif -%}

      {%- comment -%} Sold out overlay {%- endcomment -%}
      {%- unless card_available -%}
        <span class="sold-out-badge" aria-hidden="true">Sold Out</span>
      {%- endunless -%}

      {%- comment -%} Product image {%- endcomment -%}
      {%- if product.featured_image != blank -%}
        <img
          src="{{ product.featured_image | image_url: width: 600 }}"
          alt="{{ product.featured_image.alt | default: product.title | escape }}"
          loading="lazy"
          width="600"
          height="600"
          class="grid-img main-card-img">
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag: 'grid-img placeholder-svg' }}
      {%- endif -%}

    </a>

    {%- comment -%} Quick add button — hover reveals on desktop, always visible on mobile {%- endcomment -%}
    {%- form 'product', product, class: 'product-card-form', data-ajax-handled: 'true' -%}
      <input
        type="hidden"
        name="id"
        value="{{ first_variant.id }}"
        class="selected-variant-id">
      <input type="hidden" name="quantity" value="1">
      <button
        type="submit"
        name="add"
        class="quick-add-btn{% unless card_available %} is-disabled{% endunless %}"
        {% unless card_available %}disabled aria-disabled="true"{% endunless %}
        aria-label="Add {{ product.title | escape }} to cart">
        {%- if card_available -%}Add to Cart{%- else -%}Sold Out{%- endif -%}
      </button>
    {%- endform -%}

  </div>

  {%- comment -%} ── PRODUCT INFO ── {%- endcomment -%}
  <div class="product-card__info">
    <p class="brand-name">{{ product.vendor }}</p>

    <h3 class="product-card__title">
      <a href="{{ product.url }}">{{ product.title }}</a>
    </h3>

    <div class="product-card__price-row">
      <span class="product-card__price">
        {{ first_variant.price | money }}
      </span>
      {%- if first_variant.compare_at_price > first_variant.price -%}
        <span class="product-card__compare-price">
          {{ first_variant.compare_at_price | money }}
        </span>
      {%- endif -%}
    </div>

    {%- comment -%} ── VARIANT DROPDOWN (multi-variant products only) ── {%- endcomment -%}
    {%- if product.variants.size > 1 -%}
      <details class="grid-variant-disclosure" id="disclosure-{{ product.id }}">
        <summary
          class="grid-variant-summary"
          aria-label="Select variant for {{ product.title | escape }}">
          <span class="grid-variant-summary__label" id="label-{{ product.id }}">Select option</span>
          <svg class="grid-variant-summary__chevron" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <polyline points="6 9 12 15 18 9"/>
          </svg>
        </summary>

        <div class="grid-variant-dropdown" role="listbox" aria-label="Variants for {{ product.title | escape }}">
          {%- for variant in product.variants -%}
            <button
              type="button"
              class="grid-variant-option{% unless variant.available %} is-unavailable{% endunless %}"
              role="option"
              data-variant-id="{{ variant.id }}"
              data-variant-price="{{ variant.price | money }}"
              data-variant-available="{{ variant.available }}"
              data-variant-image="{{ variant.featured_image | image_url: width: 600 }}"
              data-parent-label="label-{{ product.id }}"
              data-title="{{ variant.title | escape }}"
              onclick="window.selectGridVariant(this)"
              aria-label="{{ variant.title }}{% unless variant.available %} — sold out{% endunless %}">
              <span class="grid-variant-option__title">{{ variant.title }}</span>
              <span class="grid-variant-option__price">{{ variant.price | money }}</span>
              {%- unless variant.available -%}
                <span class="grid-variant-option__sold-out">Sold out</span>
              {%- endunless -%}
            </button>
          {%- endfor -%}
        </div>
      </details>
    {%- endif -%}

  </div>
</div>


<style>
  /* ─── CARD WRAPPER ─── */
  .studio-product-card {
    position: relative;
    transition: z-index 0s;
  }

  .studio-product-card:hover,
  .studio-product-card:focus-within {
    z-index: var(--z-raised);
  }

  /* ─── IMAGE FRAME ─── */
  /* image-frame base styles live in critical.css */
  /* Only card-specific overrides here */

  .product-card__image-link {
    display: block;
    height: 100%;
  }

  /* ─── QUICK ADD FORM ─── */
  .product-card-form {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    z-index: var(--z-raised);
    transform: translateY(100%);
    transition: transform 0.28s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .studio-product-card:hover .product-card-form,
  .studio-product-card:focus-within .product-card-form {
    transform: translateY(0);
  }

  /* Override quick-add-btn base from critical.css for card context */
  .product-card-form .quick-add-btn {
    position: relative;
    left: auto;
    bottom: auto;
    transform: none;
    opacity: 1;
    width: 100%;
    border-radius: 0;
    padding: 11px;
    font-size: 10px;
  }

  .product-card-form .quick-add-btn.is-disabled {
    background: var(--color-surface);
    color: var(--text-muted);
    cursor: not-allowed;
  }

  /* ─── PRICE ROW ─── */
  .product-card__price-row {
    display: flex;
    align-items: baseline;
    gap: 6px;
    flex-wrap: wrap;
  }

  .product-card__compare-price {
    font-size: 11px;
    color: var(--text-muted);
    text-decoration: line-through;
  }

  /* ─── VARIANT DROPDOWN ─── */
  .grid-variant-disclosure {
    position: relative;
    margin-top: var(--space-xs);
    z-index: var(--z-raised);
  }

  .grid-variant-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px var(--space-xs);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-maroon);
    border: var(--border-maroon);
    cursor: pointer;
    list-style: none;
    transition: var(--transition-fast);
  }

  .grid-variant-summary::-webkit-details-marker {
    display: none;
  }

  .grid-variant-summary:hover {
    background: var(--color-maroon-ghost);
  }

  .grid-variant-summary__chevron {
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  .grid-variant-disclosure[open] .grid-variant-summary__chevron {
    transform: rotate(180deg);
  }

  .grid-variant-dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    width: 100%;
    background: var(--color-white);
    border: var(--border-maroon);
    border-top: none;
    z-index: calc(var(--z-overlay) + 1);
    box-shadow: 0 8px 24px rgba(26, 10, 10, 0.12);
    max-height: 180px;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: var(--color-maroon) var(--color-surface);
  }

  .grid-variant-option {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-xs);
    width: 100%;
    padding: 9px var(--space-xs);
    font-size: 11px;
    color: var(--text-primary);
    background: none;
    border: none;
    border-bottom: var(--border-light);
    cursor: pointer;
    text-align: left;
    transition: var(--transition-fast);
  }

  .grid-variant-option:last-child {
    border-bottom: none;
  }

  .grid-variant-option:hover {
    background: var(--color-off-white);
  }

  .grid-variant-option.is-unavailable {
    opacity: 0.45;
    cursor: not-allowed;
  }

  .grid-variant-option__title {
    flex: 1;
    font-weight: 500;
  }

  .grid-variant-option__price {
    color: var(--text-muted);
    font-size: 10px;
    flex-shrink: 0;
  }

  .grid-variant-option__sold-out {
    font-size: 9px;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--text-muted);
    flex-shrink: 0;
  }

  /* ─── MOBILE: Quick add always visible ─── */
  @media screen and (max-width: 749px) {
    .product-card-form {
      position: relative;
      transform: none;
      margin-top: var(--space-xs);
    }

    .studio-product-card:hover .product-card-form,
    .studio-product-card:focus-within .product-card-form {
      transform: none;
    }

    .product-card-form .quick-add-btn {
      border-radius: var(--radius-xs);
    }
  }
</style>
