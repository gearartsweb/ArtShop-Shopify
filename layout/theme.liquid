<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>

  {%- comment -%} ── DESIGN TOKENS (must load before critical.css) ── {%- endcomment -%}
  {%- render 'css-variables' -%}

  {%- comment -%} ── CHARSET & VIEWPORT ── {%- endcomment -%}
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">

  {%- comment -%} ── FONT PRECONNECT & PRELOAD ── {%- endcomment -%}
  {%- unless settings.type_primary_font.system? -%}
    <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
    {{ settings.type_primary_font | font_url | preload_tag: as: 'font', crossorigin: 'anonymous' }}
  {%- endunless -%}

  {%- comment -%} ── CRITICAL CSS ── {%- endcomment -%}
  {{ 'critical.css' | asset_url | stylesheet_tag: preload: true }}

  {%- comment -%} ── SEO & SOCIAL META ── {%- endcomment -%}
  {%- render 'meta-tags' -%}

  {{ content_for_header }}

</head>
<body>

  {%- comment -%} ── HEADER ── {%- endcomment -%}
  <header class="site-frame-header" role="banner">
    {%- section 'header' -%}
  </header>

  {%- comment -%} ── MAIN CONTENT ── {%- endcomment -%}
  <main
    id="MainContent"
    class="content-for-layout"
    role="main"
    tabindex="-1">
    {{ content_for_layout }}
  </main>

  {%- comment -%} ── FOOTER ── {%- endcomment -%}
  <footer class="site-frame-footer" role="contentinfo">
    {%- section 'footer' -%}
  </footer>

  {%- comment -%} ── CART DRAWER ── {%- endcomment -%}
  {%- section 'cart-drawer' -%}


  {%- comment -%}
    ═══════════════════════════════════════════
    JAVASCRIPT — loaded at end of body
    One script tag per concern. No duplicates.
    ═══════════════════════════════════════════
  {%- endcomment -%}

  {%- comment -%} ── 1. SCROLL REVEAL ── {%- endcomment -%}
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      if (!('IntersectionObserver' in window)) return;

      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.08 });

      document.querySelectorAll('.reveal-on-scroll').forEach(function(el) {
        observer.observe(el);
      });
    });
  </script>


  {%- comment -%} ── 2. CART: GLOBAL ADD-TO-CART INTERCEPTOR ── {%- endcomment -%}
  <script>
    /**
     * Intercepts ALL standard Shopify form submits to /cart/add.
     * Product-specific AJAX handlers (product.liquid, zigzag) call
     * this logic themselves — this is the safety net for any
     * form that doesn't have its own handler.
     */
    document.addEventListener('submit', function(e) {
      var form = e.target;

      /* Only intercept cart/add forms that haven't opted out */
      if (!form.matches('[action*="/cart/add"]')) return;
      if (form.dataset.ajaxHandled) return;

      e.preventDefault();

      var submitBtn = form.querySelector('[type="submit"]');
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.style.opacity = '0.7';
      }

      fetch(window.Shopify.routes.root + 'cart/add.js', {
        method: 'POST',
        body: new FormData(form)
      })
      .then(function(res) {
        if (!res.ok) throw new Error('Cart add failed');
        return res.json();
      })
      .then(function() {
        /* Update cart count bubble */
        if (window.TheArtShop && TheArtShop.updateCartCount) {
          TheArtShop.updateCartCount();
        } else if (window.updateCartCountBubble) {
          window.updateCartCountBubble();
        }

        /* Refresh drawer then open */
        if (window.refreshDrawer) {
          window.refreshDrawer().then(function() {
            if (window.toggleCart) window.toggleCart();
          });
        } else if (window.toggleCart) {
          window.toggleCart();
        }
      })
      .catch(function(err) {
        console.error('Add to Cart error:', err);
        /* Fallback: let the form submit normally */
        form.dataset.ajaxHandled = 'skip';
        form.submit();
      })
      .finally(function() {
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.style.opacity = '1';
        }
      });
    });
  </script>


  {%- comment -%} ── 3. CART DRAWER: POINTER-EVENTS FIX ── {%- endcomment -%}
  <style>
    /* Prevents click events being swallowed by svg/span inside buttons */
    .cart-drawer-item button { pointer-events: all; }
    .cart-drawer-item button * { pointer-events: none; }
  </style>


  {%- comment -%} ── 4. GRID VARIANT SELECTOR ── {%- endcomment -%}
  <script>
    /**
     * Handles variant selection in product grid cards.
     * Called by the dropdown buttons in product-card.liquid.
     */
    window.selectGridVariant = function(button) {
      var card        = button.closest('.studio-product-card');
      var variantId   = button.getAttribute('data-variant-id');
      var price       = button.getAttribute('data-variant-price');
      var isAvailable = button.getAttribute('data-variant-available') === 'true';
      var newImage    = button.getAttribute('data-variant-image');
      var labelId     = button.getAttribute('data-parent-label');

      /* Update hidden variant input */
      var input = card.querySelector('.selected-variant-id');
      if (input) input.value = variantId;

      /* Update price display */
      var priceEl = card.querySelector('.product-card__price');
      if (priceEl && price) priceEl.textContent = price;

      /* Update label in summary */
      if (labelId) {
        var label = document.getElementById(labelId);
        if (label) label.textContent = button.getAttribute('data-title');
      }

      /* Update add to cart button */
      var addBtn = card.querySelector('.quick-add-btn');
      if (addBtn) {
        addBtn.disabled = !isAvailable;
        addBtn.textContent = isAvailable ? 'Add to Cart' : 'Sold Out';
        addBtn.classList.toggle('is-disabled', !isAvailable);
      }

      /* Update image safely */
      var imgEl = card.querySelector('.grid-img');
      if (imgEl && newImage && newImage !== 'null' && !newImage.includes('Liquid error')) {
        var tmp = new Image();
        tmp.onload = function() { imgEl.src = newImage; };
        tmp.src = newImage;
      }

      /* Close the disclosure */
      var disclosure = card.querySelector('.grid-variant-disclosure');
      if (disclosure) disclosure.removeAttribute('open');
    };
  </script>


  {%- comment -%} ── 5. CUSTOM SCRIPTS (UI tweaks — loaded last, deferred) ── {%- endcomment -%}
  <script src="{{ 'custom-scripts.js' | asset_url }}" defer="defer"></script>


</body>
</html>
